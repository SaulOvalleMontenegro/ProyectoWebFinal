# ============================================================
# SKYSHIP EXPRESS – Backend (.env)
# Copia este archivo como .env y completa tus valores
# ============================================================

# Flask
FLASK_ENV=development
SECRET_KEY=cambia-esto-en-produccion-usa-una-clave-segura
JWT_SECRET_KEY=cambia-esto-jwt-en-produccion-usa-una-clave-segura

# ── Pepper de contraseñas ────────────────────────────────────
# Secreto adicional que se añade a cada contraseña ANTES de hashear.
# Nunca se guarda en la BD. Cámbialo en producción y guárdalo seguro.
# Si lo cambias, todos los usuarios deberán restablecer su contraseña.
PASSWORD_PEPPER=skyship-pepper-cambia-esto-en-produccion

# ── Base de datos MySQL (Local) ──────────────────────────────
DB_USER=root
DB_PASSWORD=tu_contraseña_local
DB_HOST=localhost
DB_PORT=3306
DB_NAME=skyship_db

# ── Base de datos MySQL (AWS RDS – Producción) ───────────────
# Descomenta estas líneas cuando despliegues en AWS:
# DB_USER=admin
# DB_PASSWORD=tu_contraseña_rds
# DB_HOST=skyship.xxxxxxxx.us-east-1.rds.amazonaws.com
# DB_PORT=3306
# DB_NAME=skyship_db

# ── CORS (origen del frontend) ───────────────────────────────
# Desarrollo local:
CORS_ORIGINS=http://localhost:5173

# AWS CloudFront (Producción) – descomenta y ajusta:
# CORS_ORIGINS=https://dxxxxxxxxxxxx.cloudfront.net

# ── Puerto del servidor ──────────────────────────────────────
PORT=5000
